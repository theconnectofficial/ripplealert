# RippleAlert — Environment Variables
# Copy this file to .env and fill in your keys.
# NEVER commit .env to GitHub.

# ── Gemini AI (patch issue generation) ─────────────────────────────────
# Get a key from: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=AIzaSyCGyZWA9a7gU5TpLnhLiN6XpSf_P979N2g

# ── Supabase Auth (GitHub OAuth) ───────────────────────────────────────
# 1. Create a free project at https://supabase.com
# 2. Project Settings → API → copy the "Project URL" and "anon public" key
# 3. Authentication → Providers → enable GitHub
# 4. Create a GitHub OAuth App at https://github.com/settings/developers
#    Authorization callback URL: <your-supabase-url>/auth/v1/callback
# 5. Paste the GitHub Client ID + Secret into Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
